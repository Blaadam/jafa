{
  "name": "project-name",
  "globIgnorePaths": [
    "**/*.spec.lua"
  ],
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "Shared": {
        "$className": "Folder",
        "Facilitators": {
          "$path": "./shared/facilitators"
        },
        "Modules": {
          "$path": "./shared/modules"
        },
        "Databases": {
          "$path": "./shared/databases"
        }
      },
      "Client": {
        "$className": "Folder",
        "Services": {
          "$path": "./client/services"
        },
        "Controllers": {
          "$path": "./client/controllers"
        },
        "Modules": {
          "$path": "./client/modules"
        },
        "ClientMain": {
          "$path": "./client/ClientMain.client.luau"
        }
      },
      "UI": {
        "$path": "./ui"
      },
      "LogConfig": {
        "$path": "./shared/LogConfig.luau"
      }
    },
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "Services": {
        "$path": "./server/services"
      },
      "Modules": {
        "$path": "./server/modules"
      },
      "ServerMain": {
        "$path": "./server/ServerMain.server.luau"
      }
    },
    "Workspace": {
      "$className": "Workspace",
      "$properties": {
        "FilteringEnabled": true,
        "StreamingEnabled": true,
        "ModelStreamingBehavior": "Improved",
        "StreamOutBehavior": "Opportunistic"
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "CanCollide": false,
          "Material": "Concrete",
          "Size": [2048, 1, 2048],
          "Position": [0, 0.5, 0]
        }
      }
    }
  }
}